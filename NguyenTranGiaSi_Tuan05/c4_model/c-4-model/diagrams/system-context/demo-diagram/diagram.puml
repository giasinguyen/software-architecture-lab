@startuml

!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

Person(editor, "Content Editor", "Tạo và quản lý nội dung trong CMS.")

Person(admin, "CMS Admin", "Quản lý cấu hình hệ thống và plugin.")

Person(developer, "Plugin Developer", "Xây dựng và cài đặt plugin mới.")

System(pluginCMS, "Plugin CMS", "Hệ thống quản lý nội dung với kiến trúc Microkernel. Xây dựng bằng Spring Boot.")

